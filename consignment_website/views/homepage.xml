<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="homepage" name="Homepage">
        <t t-call="consignment_website.layout">

            <!-- HERO -->
            <section class="ca-hero">
                <div class="ca-hero-bg">
                    <img src="https://images.unsplash.com/photo-1565008447742-97f6f38c985c?auto=format&amp;fit=crop&amp;w=2400&amp;q=85" alt="Industrial machinery"/>
                </div>
                <div class="ca-hero-content">
                    <div data-reveal="">
                        <span class="ca-eyebrow">Industrial machinery consignment · Est. 2010</span>
                        <h1>Move equipment <em>that matters.</em></h1>
                        <p class="ca-hero-sub">For fifteen years we've sold the machines that built somebody else's factory. Quietly. Transparently. Without the games of brokers or the silence of marketplaces.</p>
                        <div class="ca-hero-cta">
                            <a href="/contact" class="ca-btn ca-btn-primary ca-btn-arrow">Request appraisal</a>
                            <a href="/services" class="ca-btn ca-btn-ghost">Our approach</a>
                        </div>
                    </div>
                </div>
                <div class="ca-hero-marker">N° 001 — Consignment as craft</div>
                <div class="ca-hero-scroll">Scroll</div>
            </section>

            <!-- STATEMENT -->
            <section class="ca-section ca-section-elev">
                <div class="ca-container">
                    <div class="ca-statement" data-reveal="">
                        <p class="ca-statement-meta">A statement of intent</p>
                        <p class="ca-statement-text">Idle machinery is <em>capital, sleeping.</em> We wake it.</p>
                    </div>
                </div>
            </section>

            <!-- FOR SELLERS — image left, text right -->
            <section class="ca-section ca-section-light">
                <div class="ca-container">
                    <div class="ca-split">
                        <div class="ca-split-image" data-reveal="">
                            <img src="https://images.unsplash.com/photo-1581092334651-ddf26d9a09d0?auto=format&amp;fit=crop&amp;w=1200&amp;q=85" alt="Factory floor"/>
                            <div class="ca-split-image-tag">For sellers</div>
                        </div>
                        <div class="ca-split-text" data-reveal="" data-reveal-delay="1">
                            <span class="ca-eyebrow" style="color: var(--ca-fg-on-light-soft);">For sellers</span>
                            <h2>Equipment becomes capital again.</h2>
                            <p class="ca-lede">You ship it once. We photograph, list, negotiate, sell, ship, and pay. One commission, paid out of the sale — never out of pocket.</p>
                            <ul class="ca-split-list">
                                <li>
                                    <span class="ca-split-list-num">i.</span>
                                    <span class="ca-split-list-text"><strong>Free, same-day appraisal</strong><span>Honest market valuation, not a flattering guess.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">ii.</span>
                                    <span class="ca-split-list-text"><strong>Studio-quality photography</strong><span>On site or at our warehouse.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">iii.</span>
                                    <span class="ca-split-list-text"><strong>Listed on our marketplace + eBay</strong><span>Multi-channel, full technical write-up.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">iv.</span>
                                    <span class="ca-split-list-text"><strong>Real-time owner portal</strong><span>Status, views, offers, payouts. Live.</span></span>
                                </li>
                            </ul>
                            <div class="ca-mt-5">
                                <a href="/services" class="ca-btn-quiet ca-btn-arrow">Read our approach</a>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- FOR BUYERS — text left, image right -->
            <section class="ca-section">
                <div class="ca-container">
                    <div class="ca-split">
                        <div class="ca-split-text" data-reveal="">
                            <span class="ca-eyebrow">For buyers</span>
                            <h2>Inventory you can trust on the first phone call.</h2>
                            <p class="ca-lede">Every listing is hands-on inspected, documented, and photographed. You negotiate with our sales team — not the original owner, not a broker, not a stranger online.</p>
                            <ul class="ca-split-list">
                                <li>
                                    <span class="ca-split-list-num">i.</span>
                                    <span class="ca-split-list-text"><strong>Verified inventory</strong><span>Inspection report and condition grade on every item.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">ii.</span>
                                    <span class="ca-split-list-text"><strong>Direct negotiation</strong><span>One point of contact, no telephone game.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">iii.</span>
                                    <span class="ca-split-list-text"><strong>Escrow-backed checkout</strong><span>Funds clear before the truck moves.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">iv.</span>
                                    <span class="ca-split-list-text"><strong>12-month warranty</strong><span>On every unit. In writing.</span></span>
                                </li>
                            </ul>
                            <div class="ca-mt-5">
                                <a href="/contact" class="ca-btn-quiet ca-btn-arrow">Speak with a buyer rep</a>
                            </div>
                        </div>
                        <div class="ca-split-image" data-reveal="" data-reveal-delay="1">
                            <img src="https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?auto=format&amp;fit=crop&amp;w=1200&amp;q=85" alt="Industrial CNC"/>
                            <div class="ca-split-image-tag">For buyers</div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- PROCESS -->
            <section class="ca-section ca-section-elev">
                <div class="ca-container">
                    <div class="ca-page-head" data-reveal="">
                        <span class="ca-eyebrow">The full cycle</span>
                        <h2>From phone call to payout.</h2>
                        <p class="ca-lede">No hand-offs, no bottlenecks. One team handles every step.</p>
                    </div>
                    <div class="ca-process">
                        <div class="ca-process-item" data-reveal="" data-reveal-delay="1">
                            <div class="ca-process-num">i.</div>
                            <h4>Submit</h4>
                            <p>Tell us what you have. Same-day valuation.</p>
                        </div>
                        <div class="ca-process-item" data-reveal="" data-reveal-delay="2">
                            <div class="ca-process-num">ii.</div>
                            <h4>Inspect</h4>
                            <p>Hands-on assessment, condition report, photography.</p>
                        </div>
                        <div class="ca-process-item" data-reveal="" data-reveal-delay="3">
                            <div class="ca-process-num">iii.</div>
                            <h4>List</h4>
                            <p>Published on our site and on eBay simultaneously.</p>
                        </div>
                        <div class="ca-process-item" data-reveal="" data-reveal-delay="4">
                            <div class="ca-process-num">iv.</div>
                            <h4>Sell &amp; Ship</h4>
                            <p>We negotiate, escrow, and book the freight.</p>
                        </div>
                        <div class="ca-process-item" data-reveal="" data-reveal-delay="4">
                            <div class="ca-process-num">v.</div>
                            <h4>Pay out</h4>
                            <p>Net amount auto-credited to your wallet.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- METRICS -->
            <section class="ca-section">
                <div class="ca-container">
                    <div class="ca-page-head" data-reveal="">
                        <span class="ca-eyebrow">By the numbers</span>
                        <h2>Fifteen years, measured.</h2>
                    </div>
                    <div class="ca-metrics">
                        <div class="ca-metric" data-reveal="" data-reveal-delay="1">
                            <div class="ca-metric-num">1,000<em>+</em></div>
                            <div class="ca-metric-label">Machines sold</div>
                        </div>
                        <div class="ca-metric" data-reveal="" data-reveal-delay="2">
                            <div class="ca-metric-num">€85<em>m</em></div>
                            <div class="ca-metric-label">Equipment value transacted</div>
                        </div>
                        <div class="ca-metric" data-reveal="" data-reveal-delay="3">
                            <div class="ca-metric-num">50<em>+</em></div>
                            <div class="ca-metric-label">Countries shipped to</div>
                        </div>
                        <div class="ca-metric" data-reveal="" data-reveal-delay="4">
                            <div class="ca-metric-num">14<em>d</em></div>
                            <div class="ca-metric-label">Median time to first offer</div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- TESTIMONIAL -->
            <section class="ca-section ca-section-light">
                <div class="ca-narrow">
                    <div class="ca-quote" data-reveal="">
                        <span class="ca-quote-mark">“</span>
                        <p class="ca-quote-text">We had three idle CNCs tying up the shop floor. CondorAutomation moved all three in under five weeks — pricing was honest, communications were tight, and the wallet portal made tracking effortless.</p>
                        <p class="ca-quote-meta">— Operations Director · Mid-sized fabricator, Andalucía</p>
                    </div>
                </div>
            </section>

            <!-- CTA -->
            <section class="ca-cta">
                <div class="ca-narrow" data-reveal="">
                    <span class="ca-cta-mark">N° 002</span>
                    <h2>When the moment comes, <em>we move fast.</em></h2>
                    <p class="ca-cta-sub">Same-day response. Free appraisal. We tell you in twenty-four hours what your equipment is worth and how quickly we can move it.</p>
                    <div class="ca-row" style="justify-content: center;">
                        <a href="/contact" class="ca-btn ca-btn-primary ca-btn-arrow">Request appraisal</a>
                        <a href="/services" class="ca-btn ca-btn-ghost">Our approach</a>
                    </div>
                </div>
            </section>

        </t>
    </template>
</odoo>
