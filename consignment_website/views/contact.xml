<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="contact" name="Contact">
        <t t-call="consignment_website.layout">

            <!-- HERO -->
            <section class="ca-hero-inner">
                <div class="ca-container" data-reveal="">
                    <span class="ca-eyebrow">N° 009 — Contact</span>
                    <h1>Tell us what you have — <em>or what you need.</em></h1>
                    <p class="ca-lede">Same-day reply. Free appraisals for sellers. Verified inventory for buyers. No tire-kicker filler.</p>
                </div>
            </section>

            <!-- PATH SELECTOR + FORM -->
            <section class="ca-section">
                <div class="ca-narrow">
                    <div data-reveal="">
                        <div class="ca-paths" id="ca-paths">
                            <button type="button" class="ca-path active" data-path="seller">
                                <span class="ca-path-num">i.</span>
                                <h3>I have equipment to sell</h3>
                                <p>Get a free, same-day valuation. We come to you for inspection or you ship to us.</p>
                            </button>
                            <button type="button" class="ca-path" data-path="buyer">
                                <span class="ca-path-num">ii.</span>
                                <h3>I'm looking to buy</h3>
                                <p>Tell us what you need. Our team matches you with verified inventory or sourcing options.</p>
                            </button>
                        </div>
                    </div>

                    <form action="/contact/submit" method="post" class="ca-form" data-reveal="" data-reveal-delay="1">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="inquiry_type" id="inquiry_type" value="seller"/>

                        <div class="ca-form-row">
                            <div class="ca-field">
                                <label for="name" class="ca-label">Full name</label>
                                <input type="text" id="name" name="name" class="ca-input" required="required" placeholder="Maria Hernández"/>
                            </div>
                            <div class="ca-field">
                                <label for="company" class="ca-label">Company</label>
                                <input type="text" id="company" name="company" class="ca-input" placeholder="Your company"/>
                            </div>
                        </div>

                        <div class="ca-form-row">
                            <div class="ca-field">
                                <label for="email" class="ca-label">Email</label>
                                <input type="email" id="email" name="email" class="ca-input" required="required" placeholder="maria@company.com"/>
                            </div>
                            <div class="ca-field">
                                <label for="phone" class="ca-label">Phone</label>
                                <input type="tel" id="phone" name="phone" class="ca-input" placeholder="+34 600 000 000"/>
                            </div>
                        </div>

                        <div class="ca-form-seller-only">
                            <div class="ca-form-row">
                                <div class="ca-field">
                                    <label for="equipment_type" class="ca-label">Equipment type</label>
                                    <input type="text" id="equipment_type" name="equipment_type" class="ca-input" placeholder="e.g. CNC milling machine, hydraulic press"/>
                                </div>
                                <div class="ca-field">
                                    <label for="location" class="ca-label">Location</label>
                                    <input type="text" id="location" name="location" class="ca-input" placeholder="City, country"/>
                                </div>
                            </div>
                        </div>

                        <div class="ca-form-buyer-only ca-hidden">
                            <div class="ca-form-row">
                                <div class="ca-field">
                                    <label for="looking_for" class="ca-label">What are you looking for?</label>
                                    <input type="text" id="looking_for" name="looking_for" class="ca-input" placeholder="e.g. 5-axis CNC, used industrial robots"/>
                                </div>
                                <div class="ca-field">
                                    <label for="budget" class="ca-label">Approximate budget</label>
                                    <input type="text" id="budget" name="budget" class="ca-input" placeholder="e.g. €50,000 — €100,000"/>
                                </div>
                            </div>
                        </div>

                        <div class="ca-field ca-field-full">
                            <label for="message" class="ca-label">Message</label>
                            <textarea id="message" name="message" class="ca-textarea" required="required" placeholder="Tell us about your equipment or what you're looking for…"></textarea>
                        </div>

                        <div class="ca-mt-5">
                            <button type="submit" class="ca-btn ca-btn-primary ca-btn-arrow">Send message</button>
                            <p class="ca-form-meta">Reply within twenty-four hours. By submitting you agree we may contact you about your inquiry. We don't share your details.</p>
                        </div>
                    </form>
                </div>
            </section>

            <!-- DIRECT CONTACT -->
            <section class="ca-section ca-section-elev">
                <div class="ca-container">
                    <div class="ca-page-head" data-reveal="">
                        <span class="ca-eyebrow">Or reach us directly</span>
                        <h2>Prefer phone or email? <em>Go ahead.</em></h2>
                    </div>
                    <div class="ca-contact-direct">
                        <div class="ca-contact-card" data-reveal="" data-reveal-delay="1">
                            <div class="ca-contact-card-label">Email</div>
                            <div class="ca-contact-card-value">
                                <a href="mailto:lajefa@condorautomation.com">lajefa@condorautomation.com</a>
                            </div>
                            <div class="ca-contact-card-meta">Replies within 24 hours, weekdays and weekends.</div>
                        </div>
                        <div class="ca-contact-card" data-reveal="" data-reveal-delay="2">
                            <div class="ca-contact-card-label">Phone</div>
                            <div class="ca-contact-card-value">
                                <a href="tel:+34695986081">(+34) 695 98 60 81</a>
                            </div>
                            <div class="ca-contact-card-meta">Available 24/7 for urgent appraisal requests.</div>
                        </div>
                    </div>
                </div>
            </section>

        </t>
    </template>

    <!-- Thank you -->
    <template id="contact_thank_you" name="Contact Thank You">
        <t t-call="consignment_website.layout">
            <section class="ca-section">
                <div class="ca-narrow">
                    <div data-reveal="">
                        <span class="ca-eyebrow">Received</span>
                        <h1 style="margin-top: 1rem;">Got it, <em><t t-esc="name"/>.</em></h1>
                        <p class="ca-lede ca-mt-5">Your message is in. A member of our team will reach out within twenty-four hours — usually faster. If your equipment is sitting on a factory floor right now and time is tight, call us directly:</p>
                        <p class="ca-mt-5" style="font-family: var(--ca-serif); font-size: 1.8rem; color: var(--ca-fg);">
                            <a href="tel:+34695986081" style="color: var(--ca-fg); border-bottom: 1px solid var(--ca-accent); padding-bottom: 0.2rem;">(+34) 695 98 60 81</a>
                        </p>
                        <div class="ca-mt-6 ca-row">
                            <a href="/" class="ca-btn ca-btn-primary ca-btn-arrow">Back to home</a>
                            <a href="/services" class="ca-btn ca-btn-ghost">Our approach</a>
                        </div>
                    </div>
                </div>
            </section>
        </t>
    </template>
</odoo>
