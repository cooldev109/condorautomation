<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="about" name="About">
        <t t-call="consignment_website.layout">

            <!-- HERO -->
            <section class="ca-hero-inner">
                <div class="ca-container" data-reveal="">
                    <span class="ca-eyebrow">N° 007 — About</span>
                    <h1>Industrial veterans, building the <em>trust layer</em> for used equipment.</h1>
                    <p class="ca-lede">We've spent fifteen years on factory floors. Now we run the consignment platform we always wished existed.</p>
                </div>
            </section>

            <!-- STORY -->
            <section class="ca-section">
                <div class="ca-container">
                    <div class="ca-split">
                        <div class="ca-split-text" data-reveal="">
                            <span class="ca-eyebrow">Our story</span>
                            <h2>Why CondorAutomation exists.</h2>
                            <p class="ca-lede">For years we watched perfectly good equipment sit idle on factory floors. Owners knew it was worth something. Buyers knew they needed it. But the market between them was broken — fragmented marketplaces, opaque pricing, scam buyers, brokers who took fat margins for doing the bare minimum.</p>
                            <p>We started CondorAutomation in 2010 to fix that. One team, one transparent commission, one platform that actually shows owners what's happening with their machines. No black box. No hidden fees. No broker games.</p>
                            <p>Today we move equipment for manufacturers, fabricators, and industrial facilities across Europe and beyond — and every owner can see, in real time, exactly where their assets stand.</p>
                        </div>
                        <div class="ca-split-image" data-reveal="" data-reveal-delay="1">
                            <img src="https://images.unsplash.com/photo-1581092334651-ddf26d9a09d0?auto=format&amp;fit=crop&amp;w=1200&amp;q=85" alt="Industrial floor"/>
                            <div class="ca-split-image-tag">Est. 2010</div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- PULL QUOTE -->
            <section class="ca-section ca-section-light">
                <div class="ca-narrow">
                    <div class="ca-quote" data-reveal="">
                        <span class="ca-quote-mark">“</span>
                        <p class="ca-quote-text">Most consignment houses give you an email thread. We wanted to give owners a real-time dashboard.</p>
                        <p class="ca-quote-meta">— Founders' note · CondorAutomation, 2010</p>
                    </div>
                </div>
            </section>

            <!-- METRICS -->
            <section class="ca-section">
                <div class="ca-container">
                    <div class="ca-page-head" data-reveal="">
                        <span class="ca-eyebrow">By the numbers</span>
                        <h2>Fifteen years, measured.</h2>
                    </div>
                    <div class="ca-metrics">
                        <div class="ca-metric" data-reveal="" data-reveal-delay="1">
                            <div class="ca-metric-num">1,000<em>+</em></div>
                            <div class="ca-metric-label">Machines sold</div>
                        </div>
                        <div class="ca-metric" data-reveal="" data-reveal-delay="2">
                            <div class="ca-metric-num">€85<em>m</em></div>
                            <div class="ca-metric-label">Equipment value transacted</div>
                        </div>
                        <div class="ca-metric" data-reveal="" data-reveal-delay="3">
                            <div class="ca-metric-num">50<em>+</em></div>
                            <div class="ca-metric-label">Countries shipped to</div>
                        </div>
                        <div class="ca-metric" data-reveal="" data-reveal-delay="4">
                            <div class="ca-metric-num">98<em>%</em></div>
                            <div class="ca-metric-label">Owner satisfaction</div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- VALUES -->
            <section class="ca-section ca-section-elev">
                <div class="ca-container">
                    <div class="ca-page-head" data-reveal="">
                        <span class="ca-eyebrow">What we stand for</span>
                        <h2>Four values. <em>No fluff.</em></h2>
                    </div>
                    <div class="ca-values">
                        <div class="ca-value" data-reveal="" data-reveal-delay="1">
                            <div class="ca-value-num">i.</div>
                            <div>
                                <h4>Transparency</h4>
                                <p>One commission rate, one portal, one source of truth. Owners see what we see — sale price, fees, payout — live.</p>
                            </div>
                        </div>
                        <div class="ca-value" data-reveal="" data-reveal-delay="2">
                            <div class="ca-value-num">ii.</div>
                            <div>
                                <h4>Speed</h4>
                                <p>Production downtime costs more than commission. We respond same-day, photograph within a week, list within ten days.</p>
                            </div>
                        </div>
                        <div class="ca-value" data-reveal="" data-reveal-delay="3">
                            <div class="ca-value-num">iii.</div>
                            <div>
                                <h4>Expertise</h4>
                                <p>We know what's in front of us. CNCs, presses, robotics, automation lines. Honest condition assessments, accurate market pricing.</p>
                            </div>
                        </div>
                        <div class="ca-value" data-reveal="" data-reveal-delay="4">
                            <div class="ca-value-num">iv.</div>
                            <div>
                                <h4>Reliability</h4>
                                <p>Escrow-backed transactions. 12-month warranty. Verified buyers. We mean what we say and we put it in writing.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- CTA -->
            <section class="ca-cta">
                <div class="ca-narrow" data-reveal="">
                    <span class="ca-cta-mark">N° 008</span>
                    <h2>Let's <em>work together.</em></h2>
                    <p class="ca-cta-sub">Whether you have equipment to sell or you're sourcing for your next install — we're a phone call away.</p>
                    <div class="ca-row" style="justify-content: center;">
                        <a href="/contact" class="ca-btn ca-btn-primary ca-btn-arrow">Contact us</a>
                    </div>
                </div>
            </section>

        </t>
    </template>
</odoo>
