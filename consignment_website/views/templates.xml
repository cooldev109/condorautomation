<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="layout" name="Base Layout">
        <t t-call="website.layout">
            <t t-set="pageName" t-value="'consignment_website'"/>
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>

            <!-- Google Fonts: Cormorant Garamond + Inter -->
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="crossorigin"/>
            <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&amp;family=Inter:wght@300;400;500;600&amp;display=swap"/>

            <header class="ca-header" id="ca-header">
                <nav class="ca-nav">
                    <a href="/" class="ca-brand">
                        <img src="/consignment_core/static/src/img/condor_logo.jpg" alt="CondorAutomation"/>
                    </a>

                    <div class="ca-nav-center">
                        <a href="/" class="ca-nav-link">Home</a>
                        <a href="/services" class="ca-nav-link">Services</a>
                        <a href="/why-choose-us" class="ca-nav-link">Approach</a>
                        <a href="/about" class="ca-nav-link">About</a>
                        <a href="/contact" class="ca-nav-link">Contact</a>
                    </div>

                    <div class="ca-nav-right">
                        <div class="ca-lang" id="ca-lang">
                            <a href="?lang=en_US" data-lang="en">EN</a>
                            <span style="opacity: 0.4;">/</span>
                            <a href="?lang=es_ES" data-lang="es">ES</a>
                        </div>
                        <a href="/contact" class="ca-btn ca-btn-primary">Get appraisal</a>
                    </div>
                </nav>
            </header>

            <main>
                <t t-out="0"/>
            </main>

            <footer class="ca-footer">
                <div class="ca-container">
                    <div class="ca-footer-grid">
                        <div>
                            <div class="ca-footer-brand">CondorAutomation</div>
                            <p class="ca-footer-tag">Industrial machinery consignment. We move equipment that matters — quietly, transparently, and without games.</p>
                        </div>
                        <div>
                            <h5>For Sellers</h5>
                            <ul>
                                <li><a href="/services">Consignment</a></li>
                                <li><a href="/why-choose-us">Approach</a></li>
                                <li><a href="/contact">Free appraisal</a></li>
                            </ul>
                        </div>
                        <div>
                            <h5>For Buyers</h5>
                            <ul>
                                <li><a href="/services">How we list</a></li>
                                <li><a href="/about">About us</a></li>
                                <li><a href="/contact">Talk to a rep</a></li>
                            </ul>
                        </div>
                        <div>
                            <h5>Direct</h5>
                            <div class="ca-footer-contact">
                                <a href="mailto:lajefa@condorautomation.com">lajefa@condorautomation.com</a><br/>
                                (+34) 695 98 60 81<br/>
                                <span style="color: var(--ca-fg-muted); font-size: 0.85rem;">Available 24 / 7</span>
                            </div>
                        </div>
                    </div>
                    <div class="ca-footer-bottom">
                        <span>© 2026 CondorAutomation. All rights reserved.</span>
                        <span>Crafted in Andalucía. Served worldwide.</span>
                    </div>
                </div>
            </footer>
        </t>
    </template>
</odoo>
