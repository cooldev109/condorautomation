<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="services" name="Services">
        <t t-call="consignment_website.layout">

            <!-- HERO -->
            <section class="ca-hero-inner">
                <div class="ca-container" data-reveal="">
                    <span class="ca-eyebrow">N° 005 — Services</span>
                    <h1>End-to-end consignment, on <em>both sides</em> of the deal.</h1>
                    <p class="ca-lede">One team. One platform. One transparent commission. Whether you're moving equipment out or sourcing what you need, here is exactly what we do.</p>
                </div>
            </section>

            <!-- SELLERS — image left -->
            <section class="ca-section">
                <div class="ca-container">
                    <div class="ca-split">
                        <div class="ca-split-image" data-reveal="">
                            <img src="https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&amp;fit=crop&amp;w=1200&amp;q=85" alt="Industrial facility"/>
                            <div class="ca-split-image-tag">For sellers</div>
                        </div>
                        <div class="ca-split-text" data-reveal="" data-reveal-delay="1">
                            <span class="ca-eyebrow">For sellers</span>
                            <h2>We sell your equipment for you.</h2>
                            <p class="ca-lede">You ship it once. We do the rest. Commission only — paid out of the sale, not your pocket.</p>
                            <ul class="ca-split-list">
                                <li>
                                    <span class="ca-split-list-num">i.</span>
                                    <span class="ca-split-list-text"><strong>Free appraisal</strong><span>Same-day response with honest market price.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">ii.</span>
                                    <span class="ca-split-list-text"><strong>Inspection &amp; photography</strong><span>On-site visit or shipping to our warehouse.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">iii.</span>
                                    <span class="ca-split-list-text"><strong>Listing on our site + eBay</strong><span>Multi-channel exposure with full technical specs.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">iv.</span>
                                    <span class="ca-split-list-text"><strong>Negotiation &amp; sales</strong><span>Our team handles every conversation, not you.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">v.</span>
                                    <span class="ca-split-list-text"><strong>Escrow-backed payment</strong><span>Funds clear before the truck leaves.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">vi.</span>
                                    <span class="ca-split-list-text"><strong>Logistics</strong><span>Heavy haul, international freight, customs.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">vii.</span>
                                    <span class="ca-split-list-text"><strong>Wallet payout</strong><span>Net amount auto-credited.</span></span>
                                </li>
                            </ul>
                            <div class="ca-mt-5">
                                <a href="/contact" class="ca-btn ca-btn-primary ca-btn-arrow">Request appraisal</a>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- BUYERS — image right -->
            <section class="ca-section ca-section-light">
                <div class="ca-container">
                    <div class="ca-split">
                        <div class="ca-split-text" data-reveal="">
                            <span class="ca-eyebrow" style="color: var(--ca-fg-on-light-soft);">For buyers</span>
                            <h2>We source &amp; verify equipment for you.</h2>
                            <p class="ca-lede">Every listing on our platform has been hands-on inspected and documented. No third-party surprises.</p>
                            <ul class="ca-split-list">
                                <li>
                                    <span class="ca-split-list-num">i.</span>
                                    <span class="ca-split-list-text"><strong>Verified inventory</strong><span>Live listings filtered by category and condition.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">ii.</span>
                                    <span class="ca-split-list-text"><strong>Full documentation</strong><span>Condition report, specs, service history.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">iii.</span>
                                    <span class="ca-split-list-text"><strong>Site visits arranged</strong><span>See it in person before you buy.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">iv.</span>
                                    <span class="ca-split-list-text"><strong>Direct negotiation</strong><span>One point of contact — our sales team.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">v.</span>
                                    <span class="ca-split-list-text"><strong>Secure escrow checkout</strong><span>Pay only when documentation is verified.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">vi.</span>
                                    <span class="ca-split-list-text"><strong>Freight coordination</strong><span>Booked and tracked to your dock.</span></span>
                                </li>
                                <li>
                                    <span class="ca-split-list-num">vii.</span>
                                    <span class="ca-split-list-text"><strong>12-month warranty</strong><span>On every purchase. Period.</span></span>
                                </li>
                            </ul>
                            <div class="ca-mt-5">
                                <a href="/contact" class="ca-btn ca-btn-ghost ca-btn-arrow">Talk to a buyer rep</a>
                            </div>
                        </div>
                        <div class="ca-split-image" data-reveal="" data-reveal-delay="1">
                            <img src="https://images.unsplash.com/photo-1518709268805-4e9042af2176?auto=format&amp;fit=crop&amp;w=1200&amp;q=85" alt="Industrial machinery detail"/>
                            <div class="ca-split-image-tag">For buyers</div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- PRICING -->
            <section class="ca-section">
                <div class="ca-container">
                    <div class="ca-page-head" data-reveal="">
                        <span class="ca-eyebrow">Pricing</span>
                        <h2>Performance-based commission. <em>Nothing upfront.</em></h2>
                        <p class="ca-lede">You only pay if we sell. The commission comes out of the sale price, not on top of it.</p>
                    </div>
                    <div data-reveal="" data-reveal-delay="1">
                        <div class="ca-pricing">
                            <div class="ca-pricing-row">
                                <div class="ca-pricing-tier">Up to €25,000</div>
                                <div class="ca-pricing-rate">22%</div>
                                <div class="ca-pricing-includes">Photography, listing, sales, payment processing.</div>
                            </div>
                            <div class="ca-pricing-row">
                                <div class="ca-pricing-tier">€25,000 — €100,000</div>
                                <div class="ca-pricing-rate">20%</div>
                                <div class="ca-pricing-includes">All of the above + on-site inspection.</div>
                            </div>
                            <div class="ca-pricing-row">
                                <div class="ca-pricing-tier">€100,000 — €500,000</div>
                                <div class="ca-pricing-rate">15%</div>
                                <div class="ca-pricing-includes">All of the above + dedicated account manager.</div>
                            </div>
                            <div class="ca-pricing-row">
                                <div class="ca-pricing-tier">Over €500,000</div>
                                <div class="ca-pricing-rate">Custom</div>
                                <div class="ca-pricing-includes">Bespoke terms — let's talk.</div>
                            </div>
                        </div>
                        <p class="ca-form-meta ca-mt-5">Heavy-haul freight and international customs handled at cost — passed through with no markup.</p>
                    </div>
                </div>
            </section>

            <!-- ADD-ONS -->
            <section class="ca-section ca-section-elev">
                <div class="ca-container">
                    <div class="ca-page-head" data-reveal="">
                        <span class="ca-eyebrow">Beyond the basics</span>
                        <h2>Add-on services.</h2>
                        <p class="ca-lede">For sellers and buyers who need more than the standard cycle.</p>
                    </div>
                    <div class="ca-values">
                        <div class="ca-value" data-reveal="" data-reveal-delay="1">
                            <div class="ca-value-num">i.</div>
                            <div>
                                <h4>Independent valuation</h4>
                                <p>Need a market valuation for insurance, tax, or M&amp;A purposes? We issue formal written valuations independent of any sale process.</p>
                            </div>
                        </div>
                        <div class="ca-value" data-reveal="" data-reveal-delay="2">
                            <div class="ca-value-num">ii.</div>
                            <div>
                                <h4>Equipment sourcing</h4>
                                <p>Tell us what you're looking for. We tap our network and bring you matched equipment with verified specs — even if it's not currently listed.</p>
                            </div>
                        </div>
                        <div class="ca-value" data-reveal="" data-reveal-delay="3">
                            <div class="ca-value-num">iii.</div>
                            <div>
                                <h4>Bulk plant clearance</h4>
                                <p>Closing a facility? We handle full plant clearance — inventory, valuation, listing, dispatch — on a single project basis.</p>
                            </div>
                        </div>
                        <div class="ca-value" data-reveal="" data-reveal-delay="4">
                            <div class="ca-value-num">iv.</div>
                            <div>
                                <h4>Inspection-only service</h4>
                                <p>Buying privately and want a third-party inspection? Our engineers will inspect and report on equipment you haven't bought yet.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- CTA -->
            <section class="ca-cta">
                <div class="ca-narrow" data-reveal="">
                    <span class="ca-cta-mark">N° 006</span>
                    <h2>Tell us about <em>your equipment.</em></h2>
                    <p class="ca-cta-sub">Free appraisal in twenty-four hours. No commitment, no obligation.</p>
                    <div class="ca-row" style="justify-content: center;">
                        <a href="/contact" class="ca-btn ca-btn-primary ca-btn-arrow">Request appraisal</a>
                    </div>
                </div>
            </section>

        </t>
    </template>
</odoo>
