<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wallet Form View -->
    <record id="view_consignment_wallet_form" model="ir.ui.view">
        <field name="name">consignment.wallet.form</field>
        <field name="model">consignment.wallet</field>
        <field name="arch" type="xml">
            <form string="Consignment Wallet">
                <header>
                    <button name="action_create_payout"
                            string="Create Payout"
                            type="object"
                            class="oe_highlight"
                            invisible="balance &lt;= 0"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_transactions"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list">
                            <field name="transaction_count" widget="statinfo" string="Transactions"/>
                        </button>
                        <button name="action_view_items"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-cubes">
                            <field name="item_count" widget="statinfo" string="Items"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group name="wallet_info">
                            <field name="owner_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group name="balance_info">
                            <field name="balance" widget="monetary"
                                   decoration-success="balance &gt; 0"
                                   decoration-danger="balance &lt; 0"
                                   class="oe_subtotal_footer_separator"/>
                            <field name="pending_commission" widget="monetary"/>
                        </group>
                    </group>

                    <group string="Statistics">
                        <group>
                            <field name="total_earned" widget="monetary"/>
                        </group>
                        <group>
                            <field name="total_paid_out" widget="monetary"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Recent Transactions" name="transactions">
                            <field name="transaction_ids" nolabel="1">
                                <tree decoration-success="transaction_type in ['commission', 'adjustment_credit']"
                                      decoration-danger="transaction_type in ['payout', 'adjustment_debit']"
                                      create="0" delete="0">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="transaction_type"/>
                                    <field name="amount" widget="monetary"/>
                                    <field name="wallet_balance_after" widget="monetary"/>
                                    <field name="description"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Consignment Items" name="items">
                            <field name="item_ids" nolabel="1">
                                <tree create="0" delete="0"
                                      decoration-muted="state == 'draft'"
                                      decoration-info="state == 'received'"
                                      decoration-primary="state == 'listed'"
                                      decoration-success="state in ['sold', 'paid']">
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="state" widget="badge"
                                           decoration-muted="state == 'draft'"
                                           decoration-info="state == 'received'"
                                           decoration-primary="state == 'listed'"
                                           decoration-warning="state == 'sold'"
                                           decoration-success="state == 'paid'"/>
                                    <field name="expected_price" widget="monetary" optional="hide"/>
                                    <field name="listing_price" widget="monetary" optional="show"/>
                                    <field name="sale_price" widget="monetary" optional="show"/>
                                    <field name="net_amount" widget="monetary"/>
                                    <field name="commission_posted" widget="boolean_toggle" optional="show"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Wallet Tree View -->
    <record id="view_consignment_wallet_tree" model="ir.ui.view">
        <field name="name">consignment.wallet.tree</field>
        <field name="model">consignment.wallet</field>
        <field name="arch" type="xml">
            <tree string="Consignment Wallets"
                  decoration-muted="not active"
                  decoration-success="balance &gt; 0"
                  decoration-warning="pending_commission &gt; 0">
                <field name="name"/>
                <field name="owner_id"/>
                <field name="balance" widget="monetary"
                       decoration-success="balance &gt; 0"
                       decoration-danger="balance &lt; 0"/>
                <field name="pending_commission" widget="monetary"/>
                <field name="total_earned" widget="monetary" optional="hide"/>
                <field name="total_paid_out" widget="monetary" optional="hide"/>
                <field name="transaction_count" optional="show"/>
                <field name="item_count" optional="show"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="active" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Wallet Search View -->
    <record id="view_consignment_wallet_search" model="ir.ui.view">
        <field name="name">consignment.wallet.search</field>
        <field name="model">consignment.wallet</field>
        <field name="arch" type="xml">
            <search string="Search Wallets">
                <field name="name" string="Wallet" filter_domain="[('name', 'ilike', self)]"/>
                <field name="owner_id" string="Owner" filter_domain="[('owner_id.name', 'ilike', self)]"/>

                <!-- Note: Computed fields (balance, pending_commission) cannot be used in filters -->
                <!-- Users can see balance/pending in the list view instead -->

                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>

                <group expand="0" string="Group By">
                    <filter string="Owner" name="group_owner" context="{'group_by': 'owner_id'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Wallet Action -->
    <record id="action_consignment_wallet" model="ir.actions.act_window">
        <field name="name">Owner Wallets</field>
        <field name="res_model">consignment.wallet</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_consignment_wallet_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first wallet
            </p>
            <p>
                Wallets are automatically created when consignment items are marked as paid.
                Track commissions, manage payouts, and view transaction history here.
            </p>
        </field>
    </record>

</odoo>
