<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Transaction Form View -->
    <record id="view_consignment_wallet_transaction_form" model="ir.ui.view">
        <field name="name">consignment.wallet.transaction.form</field>
        <field name="model">consignment.wallet.transaction</field>
        <field name="arch" type="xml">
            <form string="Wallet Transaction">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group name="transaction_info">
                            <field name="date"/>
                            <field name="wallet_id" options="{'no_create': True}"/>
                            <field name="owner_id"/>
                            <field name="transaction_type"/>
                            <field name="amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group name="payment_info">
                            <field name="payment_method" invisible="transaction_type not in ['payout']"/>
                            <field name="payment_reference" invisible="transaction_type not in ['payout']"/>
                            <field name="consignment_item_id" invisible="transaction_type != 'commission'"
                                   options="{'no_create': True}"/>
                            <field name="wallet_balance_after" widget="monetary"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="Transaction description..."/>
                    </group>

                    <group string="Internal Notes">
                        <field name="notes" nolabel="1" placeholder="Internal notes..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Transaction Tree View -->
    <record id="view_consignment_wallet_transaction_tree" model="ir.ui.view">
        <field name="name">consignment.wallet.transaction.tree</field>
        <field name="model">consignment.wallet.transaction</field>
        <field name="arch" type="xml">
            <tree string="Wallet Transactions"
                  decoration-success="transaction_type in ['commission', 'adjustment_credit']"
                  decoration-danger="transaction_type in ['payout', 'adjustment_debit']"
                  default_order="date desc, id desc">
                <field name="date"/>
                <field name="name"/>
                <field name="wallet_id"/>
                <field name="owner_id"/>
                <field name="transaction_type" widget="badge"
                       decoration-success="transaction_type in ['commission', 'adjustment_credit']"
                       decoration-warning="transaction_type in ['payout', 'adjustment_debit']"/>
                <field name="amount" widget="monetary"/>
                <field name="wallet_balance_after" widget="monetary"/>
                <field name="consignment_item_id" optional="show"/>
                <field name="payment_method" optional="show"/>
                <field name="description"/>
                <field name="currency_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Transaction Search View -->
    <record id="view_consignment_wallet_transaction_search" model="ir.ui.view">
        <field name="name">consignment.wallet.transaction.search</field>
        <field name="model">consignment.wallet.transaction</field>
        <field name="arch" type="xml">
            <search string="Search Transactions">
                <field name="name" string="Reference" filter_domain="[('name', 'ilike', self)]"/>
                <field name="wallet_id" string="Wallet" filter_domain="[('wallet_id.name', 'ilike', self)]"/>
                <field name="owner_id" string="Owner" filter_domain="[('owner_id.name', 'ilike', self)]"/>
                <field name="description" string="Description" filter_domain="[('description', 'ilike', self)]"/>

                <filter string="Commission" name="commission"
                        domain="[('transaction_type', '=', 'commission')]"/>
                <filter string="Payout" name="payout"
                        domain="[('transaction_type', '=', 'payout')]"/>
                <filter string="Adjustments" name="adjustments"
                        domain="[('transaction_type', 'in', ['adjustment_credit', 'adjustment_debit'])]"/>

                <separator/>
                <filter string="Today" name="today"
                        domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Month" name="this_month"
                        domain="[('date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                 ('date', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>

                <group expand="0" string="Group By">
                    <filter string="Wallet" name="group_wallet" context="{'group_by': 'wallet_id'}"/>
                    <filter string="Owner" name="group_owner" context="{'group_by': 'owner_id'}"/>
                    <filter string="Transaction Type" name="group_type" context="{'group_by': 'transaction_type'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Transaction Action -->
    <record id="action_consignment_wallet_transaction" model="ir.actions.act_window">
        <field name="name">Wallet Transactions</field>
        <field name="res_model">consignment.wallet.transaction</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_consignment_wallet_transaction_search"/>
        <field name="context">{'search_default_this_month': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No transactions yet
            </p>
            <p>
                Transactions are automatically created when items are marked as paid,
                or when payouts are made to owners.
            </p>
        </field>
    </record>

</odoo>
