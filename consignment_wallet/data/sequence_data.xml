<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Wallet Sequence -->
        <record id="sequence_consignment_wallet" model="ir.sequence">
            <field name="name">Consignment Wallet</field>
            <field name="code">consignment.wallet</field>
            <field name="prefix">WALLET/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Wallet Transaction Sequence -->
        <record id="sequence_consignment_wallet_transaction" model="ir.sequence">
            <field name="name">Consignment Wallet Transaction</field>
            <field name="code">consignment.wallet.transaction</field>
            <field name="prefix">TXN/</field>
            <field name="padding">6</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
