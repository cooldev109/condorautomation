<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for consignment.item -->
        <record id="seq_consignment_item" model="ir.sequence">
            <field name="name">Consignment Item</field>
            <field name="code">consignment.item</field>
            <field name="prefix">CONS/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
