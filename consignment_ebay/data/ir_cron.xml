<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Scheduled Action: Import eBay Orders -->
        <record id="ir_cron_import_ebay_orders" model="ir.cron">
            <field name="name">Import eBay Orders</field>
            <field name="model_id" ref="model_ebay_order"/>
            <field name="state">code</field>
            <field name="code">model.cron_import_ebay_orders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="priority">10</field>
        </record>
    </data>
</odoo>
